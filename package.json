{
  "name": "tarantul",
  "version": "0.1.4",
  "description": "A lightweight personal AI assistant framework",
  "type": "module",
  "license": "MIT",
  "keywords": ["ai", "agent", "chatbot"],
  "bin": {
    "tarantul": "./src/cli/main.ts"
  },
  "scripts": {
    "start": "bun run src/cli/main.ts",
    "gateway": "bun run src/gateway.ts",
    "api": "bun run src/api/server.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t tarantul .",
    "docker:serve": "docker compose up -d tarantul-serve",
    "docker:stop": "docker compose down",
    "docker:cli": "docker compose run --rm tarantul-cli"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "openai": "^4.77.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "zod": "^3.24.0",
    "croner": "^9.0.0",
    "js-tiktoken": "^1.0.15",
    "node-telegram-bot-api": "^0.66.0",
    "@slack/bolt": "^4.4.0",
    "discord.js": "^14.18.0",
    "nodemailer": "^6.10.0",
    "imapflow": "^1.0.170",
    "grammy": "^1.34.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "jsonrepair": "^3.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "@types/nodemailer": "^6.4.17",
    "typescript": "^5.8.0"
  }
}
